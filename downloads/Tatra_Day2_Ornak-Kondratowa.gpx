  <wpt lat="49.231544" lon="19.909528"><name>Krzesanica</name></wpt>
  <wpt lat="49.235954" lon="19.919139"><name>Malolaczniak</name></wpt>
  <wpt lat="49.242400" lon="19.933500"><name>Kopa Kondracka ridge area</name></wpt>
  <wpt lat="49.240600" lon="19.937900"><name>Descent to Kondracka Przelecz</name></wpt>
  <wpt lat="49.245800" lon="19.944300"><name>Blue trail section</name></wpt>
  <wpt lat="49.248200" lon="19.948500"><name>Approach to Kondratowa hut</name></wpt>
  <wpt lat="49.249647" lon="19.951727"><name>Hala Kondratowa Hut</name></wpt>
